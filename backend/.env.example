# Скопируйте в .env и заполните своими значениями.
# .env — в .gitignore.

# JWT
SECRET_KEY=replace-with-random-32-char-string-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database
DATABASE_URL=sqlite:///./avtoperevozki.db

# Telegram-бот для уведомлений диспетчерам
# Создайте бота через @BotFather → получите токен.
# TELEGRAM_CHAT_ID — id группы или личный chat_id (узнать через @userinfobot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (опционально, для уведомлений)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=order@avto-perevozki.ru
SMTP_TO=dispatcher@avto-perevozki.ru

# Yandex (для серверной геокодинговой валидации, опционально)
YANDEX_API_KEY=

# Дефолтный диспетчер при первом запуске (можно поменять через админку)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin

# CORS — разрешённые origin'ы фронта
CORS_ORIGINS=http://localhost:8080,http://localhost:5500,http://127.0.0.1:8080
